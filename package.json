{
  "name": "aliexpress-tunisia-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready AliExpress Tunisia SaaS platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "render-build": "npm ci && PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium chromium-headless-shell",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "vps:update": "bash ./scripts/vps-update.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.59.1"
  }
}
